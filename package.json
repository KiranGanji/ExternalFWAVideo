{
  "name": "fraud-analytics-video",
  "private": true,
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "compositions": "remotion compositions src/index.ts",
    "render": "remotion render src/index.ts FraudAnalyticsExplainer out/fraud-analytics-explainer.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p",
    "render:light-hq": "remotion render src/index.ts FraudAnalyticsExplainer out/fraud-analytics-explainer-light-hq.mp4 --codec=h264 --crf=12 --pixel-format=yuv420p",
    "render:scenes": "node scripts/render-scenes.mjs",
    "render:4k": "remotion render src/index.ts FraudAnalyticsExplainer out/fraud-analytics-explainer-4k.mp4 --scale=2 --codec=h264 --crf=16",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/noise": "4.0.487",
    "react": "19",
    "react-dom": "19",
    "remotion": "4.0.487"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.487",
    "@types/react": "19",
    "@types/react-dom": "19",
    "typescript": "5"
  }
}
